# ===== Da3wa Server — environment variables =====
# انسخ هذا الملف إلى .env واملأ القيم

# الخادم
NODE_ENV=development
PORT=4000
# عناوين الواجهات المسموح لها (CORS) — افصل بينها بفاصلة
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# قاعدة البيانات (MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/da3wa

# المصادقة (JWT)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=4
# في بيئة التطوير يُرجَع رمز الـ OTP في الاستجابة لتسهيل الاختبار
OTP_DEBUG_RETURN=true

# روابط الدعوة العامة (تُستخدم لبناء رابط الضيف)
PUBLIC_INVITE_BASE_URL=http://localhost:3000/i
